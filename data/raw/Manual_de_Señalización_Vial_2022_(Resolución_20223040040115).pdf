<script type="text/javascript">
    $('#searchForm').validate({
        rules: {
            q: {
                minlength: 4,
                maxlength: 150
            }
        }
    });

    function ValidaLongitud(campo, longitudMaxima) {
        try {
            if (campo.value.length > (longitudMaxima - 1))
                return false;
            else
                return true;
        } catch (e) {
            return false;
        }
    }
</script></div>
