         }
	.publication-container a {
		color: #dc7240;
	}
	/* ESTILOS MOBILE CORREGIDOS */
	@media only screen and (max-width: 600px) {
		body {
			overflow-x: hidden !important;
		}
	/* Cajón de la imagen del slider */
	.dPrincipal .slider_main .item a .image {
		width: 100%;
		height: auto;
		max-height: 100%;
		display: flex;
	}
	/* Flechas del slider */
	.uSlider .defaultDynamic .slick-prev, .slick-prev {
		left: 0;
	}
	/* Pie de foto de cada slide*/
	.dPrincipal .slider_main .item .new-tools-box {
		background: #dc7240;
		min-height: auto;
	}
	.dPrincipal .slider_main .item .new-tools-box .title {
		width: auto;
	}
	.dPrincipal .slider_main .item .new-tools-box .title p {
		font-weight: 400;
		font-size: .5em;
		text-align: center;
	}
	/* Botón pausar slide */
	.uSlider .buttons {
		position: absolute;
		left: 1em;
		bottom: -2.5em;
		z-index: 3;
	}
	/* Paginador de slides */
	.slick-dots {
		display: none;
	}
	/* Barra de accesibilidad */
	.block--gov-accessibility {
		top: 50%;
		transform: translateY(-50%);
	}
	/*Botón volver arriba*/
	.scroll-to-top {
		left: 5px !important;
	}
	.scroll-to-top button .label-button-star-up {
		display: none;
	}
	}
	@media screen and (max-width: 992px) {
		.dPrincipal .slider_main .slick-next {
			right: inherit;
			left: 88% !important;
		}
	}
	/** AJUSTE NUEVO OPCIÓN SLIDER ICONOS **/
	.slider_banner.no-date .new-tools-box {
		display: none !important;
	}
	.slider_banner.icon-style.nxBlockDynamicLayout4 .dynamicStyle2 .item a.content-box+a.content-box {
		position: relative;
		top: 0;
		margin: 1rem 0 0 0;
		height: auto;
		background: none;
	}
	.slider_banner.icon-style.nxBlockDynamicLayout4 .dynamicStyle2 .item a.content-box+a.content-box:hover,
	.slider_banner.icon-style.nxBlockDynamicLayout4 .dynamicStyle2 .item a.content-box:hover+a.content-box {
		color: #FFFFFF;
		background-color: #dc7240;
	}
	.slider_banner.icon-style.nxBlockDynamicLayout4 .dynamicStyle2 .item a.content-box+a.content-box:hover .title,
	.slider_banner.icon-style.nxBlockDynamicLayout4 .dynamicStyle2 .item a.content-box:hover+a.content-box .title {
		color: #FFFFFF;
	}
	.slider-institucional .dynamicStyle2 .image {
		width: 100%;
		height: 100%;
		aspect-ratio: 1/1;
	}
	/*.slider-institucional .image img {
		width: 100%;
		height: 100%;
		object-fit: contain;
	}*/
	.slider-institucional .dynamicStyle2 .item {
		position: relative;
	}
	.slider-institucional .dynamicStyle2 .item .content-box+.content-box {
		position: absolute;
		top: 0;
		z-index: 2;
		width: calc(100% - 2rem);
		height: 100%;
		border-radius: 0 0 10px 10px;
